{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MCP Apps Configuration",
  "description": "Configuration for MCP tools that render Module Federation components",
  "type": "object",
  "required": ["remotes", "tools"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Configuration version"
    },
    "remotes": {
      "type": "array",
      "description": "Module Federation remotes configuration",
      "items": {
        "type": "object",
        "required": ["name", "baseUrl", "csp"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Remote name (e.g., @cloud-public/goofy-deploy)"
          },
          "version": {
            "type": "string",
            "description": "Remote version (informational only, not used in URL construction)"
          },
          "baseUrl": {
            "type": "string",
            "description": "Full manifest URL for the remote (e.g. https://example.com/mf-manifest.json or vmok-manifest.json)"
          },
          "manifestType": {
            "type": "string",
            "enum": ["mf", "vmok"],
            "default": "mf",
            "description": "Manifest format: 'mf' for standard Module Federation, 'vmok' for ByteDance-internal vmok format"
          },
          "snapshotUrl": {
            "type": "string",
            "description": "Optional vmok snapshot URL. If omitted, auto-derived from baseUrl by replacing vmok-manifest.json with vmok-snapshot.json"
          },
          "locale": {
            "type": "string",
            "default": "cn",
            "description": "Locale/region (informational only)"
          },
          "csp": {
            "type": "object",
            "description": "Content Security Policy configuration",
            "required": ["connectDomains", "resourceDomains"],
            "properties": {
              "connectDomains": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Allowed domains for fetch/XHR"
              },
              "resourceDomains": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Allowed domains for loading resources"
              }
            }
          }
        }
      }
    },
    "tools": {
      "type": "array",
      "description": "List of MCP tools",
      "items": {
        "type": "object",
        "required": ["name", "title", "description", "remote", "module"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Unique tool identifier (snake_case recommended)"
          },
          "title": {
            "type": "string",
            "description": "Human-readable tool name"
          },
          "description": {
            "type": "string",
            "description": "Tool description for the AI model"
          },
          "inputSchema": {
            "type": "object",
            "description": "JSON Schema for tool input parameters"
          },
          "remote": {
            "type": "string",
            "description": "Remote name reference (from remotes object)"
          },
          "module": {
            "type": "string",
            "description": "Exposed module path (e.g., ./ComponentName)"
          },
          "exportName": {
            "type": "string",
            "default": "default",
            "description": "Export name from the module"
          }
        }
      }
    }
  }
}
