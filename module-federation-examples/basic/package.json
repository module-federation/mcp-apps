{
  "name": "provider",
  "version": "0.1.0",
  "scripts": {
    "reset": "npx rimraf node_modules ./**/node_modules",
    "dev": "modern dev",
    "build": "modern build",
    "start": "modern start",
    "serve": "modern serve",
    "new": "modern new",
    "lint": "biome check",
    "prepare": "simple-git-hooks",
    "upgrade": "modern upgrade",
    "mcp": "mf-mcp-server --config ./mcp_apps.json --stdio"
  },
  "engines": {
    "node": ">=16.18.1"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --files-ignore-unknown=true"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "dependencies": {
    "@modern-js/runtime":  "3.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@modern-js/app-tools": "3.0.3",
    "@modern-js/tsconfig":  "3.0.3",
    "@biomejs/biome": "1.8.3",
    "typescript": "~5.0.4",
    "@types/jest": "~29.2.4",
    "@types/node": "~18.11.9",
    "@types/react": "^18.3.11",
    "@types/react-dom": "~18.3.1",
    "lint-staged": "~13.1.0",
    "simple-git-hooks": "^2.11.1",
    "rimraf": "^6.0.1",
    "@module-federation/modern-js-v3":"^2.0.1"
  }
}
